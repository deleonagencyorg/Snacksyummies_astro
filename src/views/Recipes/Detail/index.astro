        { /* Desktop: show product link BELOW the info row */ }
        {safeRecipe.Product && recipeBrandSlug && (
          <div class="hidden md:block mt-3">
            <a
              href={`/${currentLang}/${currentLang === 'es' ? 'productos' : 'products'}?brand=${encodeURIComponent(recipeBrandSlug)}`}
