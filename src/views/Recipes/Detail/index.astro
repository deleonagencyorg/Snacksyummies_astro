        </div>
      </div>
    </div>

    <!-- Info Recipe - Figma "Info 2" Layout -->
    <div class="flex flex-col md:flex-row gap-6 md:gap-[25px] items-start md:items-center justify-between w-full mb-12" data-name="Info 2">
