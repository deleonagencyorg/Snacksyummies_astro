<script is:inline>
  function isYouTube(url) {
    if (!url) return false;
    return /youtu\.be|youtube\.com/.test(url);
  }

  function getYouTubeId(url) {
    if (!url) return '';
    const regExp = /^.*(youtu\.be\/|v\/|u\/\w\/|embed\/|watch\?v=|shorts\/|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : '';
  }

  function isYouTubeShort(url) {
    if (!url) return false;
    return /youtube\.com\/shorts\//.test(url);
  }

  function isMobileViewport() {
    return window.matchMedia('(max-width: 767px)').matches;
  }

  function buildEmbedUrl(videoId) {
    const params = new URLSearchParams({
      autoplay: '1',
      controls: '1',
      playsinline: '1',
      rel: '0',
      modestbranding: '1'
    });

    return 'https://www.youtube.com/embed/' + videoId + '?' + params.toString();
  }

  window.openVideoModal = function(url) {
    if (!url) return;
    const modal = document.getElementById('video-modal-overlay');
    const container = document.getElementById('video-modal-container');
    const iframe = document.getElementById('video-modal-iframe');
    const videoPlayer = document.getElementById('video-modal-player');
    if (!modal || !container) return;

    if (isYouTube(url)) {
      const videoId = getYouTubeId(url);
      if (!videoId) return;

      if (videoPlayer) {
        videoPlayer.pause();
        videoPlayer.src = '';
        videoPlayer.removeAttribute('src');
        videoPlayer.load();
        videoPlayer.classList.add('hidden');
      }

      if (iframe) {
        const displayMode = isYouTubeShort(url) && isMobileViewport() ? 'shorts-mobile' : 'default';
        modal.dataset.mode = displayMode;
        container.dataset.mode = displayMode;
        iframe.src = buildEmbedUrl(videoId);
        iframe.classList.remove('hidden');
      }
    } else {
      if (iframe) {
        iframe.src = '';
        iframe.classList.add('hidden');
      }

      const isMobile = isMobileViewport();
      const displayMode = isMobile ? 'direct-video-mobile' : 'direct-video';
      modal.dataset.mode = displayMode;
      container.dataset.mode = displayMode;

      if (videoPlayer) {
        videoPlayer.src = url;
        videoPlayer.classList.remove('hidden');
        videoPlayer.play().catch(function(err) {
          console.warn('Autoplay prevented by browser:', err);
        });
      }
    }

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  window.closeVideoModal = function() {
    const modal = document.getElementById('video-modal-overlay');
    const container = document.getElementById('video-modal-container');
    const iframe = document.getElementById('video-modal-iframe');
    const videoPlayer = document.getElementById('video-modal-player');
    if (!modal || !container) return;

    if (iframe) {
      iframe.src = '';
      iframe.classList.add('hidden');
    }

    if (videoPlayer) {
      videoPlayer.pause();
      videoPlayer.src = '';
      videoPlayer.removeAttribute('src');
      videoPlayer.load();
      videoPlayer.classList.add('hidden');
    }

    modal.dataset.mode = 'default';
    container.dataset.mode = 'default';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };

  document.addEventListener('click', function(e) {
    const modal = document.getElementById('video-modal-overlay');
    if (e.target === modal) {
      window.closeVideoModal();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      window.closeVideoModal();
    }
  });
</script>

<div id="video-modal-overlay" data-mode="default" class="video-modal-overlay hidden fixed inset-0 z-[100] items-center justify-center bg-black/80 backdrop-blur-sm" onclick="if(event.target===this)window.closeVideoModal()">
  <div id="video-modal-container" data-mode="default" class="video-modal-container relative w-full max-w-4xl mx-4 aspect-video bg-black rounded-xl overflow-hidden shadow-2xl flex items-center justify-center">
    <button onclick="window.closeVideoModal()" class="absolute top-3 right-3 z-10 text-white bg-black/50 hover:bg-black/70 rounded-full p-2 transition-colors" aria-label="Close video">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <iframe id="video-modal-iframe" class="video-modal-iframe w-full h-full hidden" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen" allowfullscreen></iframe>
    <video id="video-modal-player" class="video-modal-player w-full h-full object-contain hidden" controls playsinline preload="metadata"></video>
  </div>
</div>

<style>
  .video-modal-iframe {
    border: none;
  }

  #video-modal-overlay[data-mode='shorts-mobile'] {
    background: #000;
    align-items: stretch;
    justify-content: stretch;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  #video-modal-container[data-mode='shorts-mobile'] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    max-width: none;
    margin: 0;
    aspect-ratio: auto;
    border-radius: 0;
    box-shadow: none;
  }

  #video-modal-container[data-mode='shorts-mobile'] button[aria-label='Close video'] {
    top: calc(env(safe-area-inset-top, 0px) + 0.75rem);
    right: calc(env(safe-area-inset-right, 0px) + 0.75rem);
  }

  #video-modal-container[data-mode='shorts-mobile'] .video-modal-iframe {
    width: 100%;
    height: 100%;
  }

  #video-modal-container[data-mode='direct-video'] {
    max-height: 85vh;
    aspect-ratio: auto;
    height: 80vh;
  }

  #video-modal-container[data-mode='direct-video-mobile'] {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    max-width: none;
    margin: 0;
    aspect-ratio: auto;
    border-radius: 0;
    box-shadow: none;
  }

  #video-modal-container[data-mode='direct-video-mobile'] button[aria-label='Close video'] {
    top: calc(env(safe-area-inset-top, 0px) + 0.75rem);
    right: calc(env(safe-area-inset-right, 0px) + 0.75rem);
  }
</style>
