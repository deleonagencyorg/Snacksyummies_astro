      </div>
    </div>
    <!-- All Info Section - Figma "All Info" Layout -->
    <div class="flex flex-col gap-10 items-start justify-start w-full mb-12" data-name="All info">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 w-full">
        
        <!-- Ingredients Column -->
        <div class="flex flex-col gap-6">
          <h2 class="text-xl md:text-3xl font-sans text-primary" >
            {recipesAssets.ingredients || (currentLang === 'es' ? 'Ingredientes' : 'Ingredients')}
          </h2>
          
          <ul class="flex flex-col gap-4">
            {safeRecipe.ingredients.map((ingredient: string) => (
              <li class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-primary text-md md:text-xl font-sans">
                  {ingredient}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Instructions Column -->
        <div class="flex flex-col gap-6">
          <h2 class="text-primary text-xl md:text-3xl font-sans" >
            {recipesAssets.preparation || (currentLang === 'es' ? 'Instrucciones' : 'Instructions')}
          </h2>
          
          <ol class="flex flex-col gap-4">
            {safeRecipe.instructions.map((instruction: string, index: number) => (
              <li class="flex items-start gap-3">
                <div class="flex-shrink-0 mt-1">
                  <div class="w-6 h-6 bg-white rounded-full flex items-center justify-center">
                    <span class="text-primary text-sm font-bold">{index + 1}</span>
                  </div>
                </div>
                <p class="text-primary text-md md:text-xl font-sans text-justify">
                      {instruction}
                    </p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>

    <!-- Related Recipes Section -->
    {relatedRecipes.length > 0 && (
      <div class="mt-12">
        <h2 class="text-white font-title text-[40px] font-bold leading-[40px] text-center w-full mb-8">
          {recipesAssets.related_recipes}
        </h2>
        <RelatedRecipesCarousel items={relatedRecipes} />
      </div>
    )}
  </div>
</div>

<div
  id="recipe-nav-data"
  style="display:none"
  data-current-id={safeRecipe.id}
  data-lang={currentLang}
  data-recipes={JSON.stringify(allRecipes.map(r => ({ id: r.id, slug: r.slug })))}
></div>

<script>
  import { navigate } from 'astro:transitions/client';

  let btnCleanup: (() => void) | null = null;
  let isNavigating = false;
  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  interface NavState {
    stack: string[];
    cursor: number;
    pool: string[];
  }

  interface RecipeRef { id: string; slug?: string; }
  function initRecipeNav() {
    if (btnCleanup) { btnCleanup(); btnCleanup = null; }

    const navEl = document.getElementById('recipe-nav-data');
    if (!navEl) return;

    const currentId  = navEl.dataset.currentId!;
    const currentLang = navEl.dataset.lang!;
    const allRecipes: RecipeRef[] = JSON.parse(navEl.dataset.recipes || '[]');

    if (!currentId || !currentLang || !allRecipes.length) return;

    const byId: Record<string, RecipeRef> = {};
    allRecipes.forEach(r => { byId[r.id] = r; });

    const SESSION_KEY = `recipeNav2_${currentLang}`;

    function loadState(): NavState | null {
      try { return JSON.parse(sessionStorage.getItem(SESSION_KEY) || 'null'); }
      catch { return null; }
    }
    function saveState(s: NavState) {
      sessionStorage.setItem(SESSION_KEY, JSON.stringify(s));
    }

    let s = loadState();
    const valid = s && Array.isArray(s.stack) && typeof s.cursor === 'number' && Array.isArray(s.pool);

    if (!valid) {
      const pool = shuffle(allRecipes.map(r => r.id).filter(id => id !== currentId));
      s = { stack: [currentId], cursor: 0, pool };
      saveState(s);
    } else {
      if (s!.stack[s!.cursor] === currentId) {
      }
      else {
        const existingIdx = s!.stack.lastIndexOf(currentId);

        if (existingIdx !== -1) {
          s!.cursor = existingIdx;
        } else {
          s!.stack = s!.stack.slice(0, s!.cursor + 1);
          s!.stack.push(currentId);
          s!.cursor = s!.stack.length - 1;
          const inStack = new Set<string>(s!.stack);
          s!.pool = s!.pool.filter(id => !inStack.has(id));
          if (s!.pool.length === 0) {
            s!.pool = shuffle(allRecipes.map(r => r.id).filter(id => !inStack.has(id)));
          }
        }
        saveState(s!);
      }
    }

    let state = s as NavState;

    function poolNext(): string | undefined {
      if (!state.pool.length) {
        const inStack = new Set<string>(state.stack);
        state.pool = shuffle(allRecipes.map(r => r.id).filter(id => !inStack.has(id)));
      }
      return state.pool.shift();
    }

    function goTo(id: string) {
      if (isNavigating) return;
      const recipe = byId[id];
      if (!recipe) return;
      const section = currentLang === 'es' ? 'recetas' : 'recipes';
      const slug = recipe.slug || recipe.id;
      isNavigating = true;
      navigate(`/${currentLang}/${section}/${slug}`).finally(() => { isNavigating = false; });
    }

    function onPrev(e: Event) {
      e.preventDefault(); e.stopPropagation();
      if (isNavigating || state.cursor <= 0) return;
      state.cursor--;
      saveState(state);
      goTo(state.stack[state.cursor]);
    }

    function onNext(e: Event) {
      e.preventDefault(); e.stopPropagation();
      if (isNavigating) return;
      if (state.cursor < state.stack.length - 1) {
        state.cursor++;
        saveState(state);
        goTo(state.stack[state.cursor]);
      } else {
        const nextId = poolNext();
        if (nextId) {
          state.stack.push(nextId);
          state.cursor = state.stack.length - 1;
          saveState(state);
          goTo(nextId);
        }
      }
    }

    function onKeyDown(e: KeyboardEvent) {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); onPrev(e); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); onNext(e); }
    }
    const prevBtns = Array.from(document.querySelectorAll<HTMLElement>('.recipe-prev-btn'));
    const nextBtns = Array.from(document.querySelectorAll<HTMLElement>('.recipe-next-btn'));

    prevBtns.forEach(btn => btn.addEventListener('click', onPrev));
    nextBtns.forEach(btn => btn.addEventListener('click', onNext));
    document.addEventListener('keydown', onKeyDown);

    btnCleanup = () => {
      prevBtns.forEach(btn => btn.removeEventListener('click', onPrev));
      nextBtns.forEach(btn => btn.removeEventListener('click', onNext));
      document.removeEventListener('keydown', onKeyDown);
    };
    document.querySelectorAll<HTMLImageElement>('img').forEach(img => {
      if (!img.hasAttribute('onerror')) {
        img.addEventListener('error', function(this: HTMLImageElement) {
          this.onerror = null;
          this.src = 'https://snack.yummiespromociones.com/SnacksyummiesAssets/placeholder.webp';
        });
      }
    });
  }
  document.addEventListener('astro:page-load', initRecipeNav);
</script>

