---
// src/components/recipes/Categories.astro
import { getLocale, t } from '../../i18n/i18n';

export interface CategoryItem {
  label: string;
  slug: string;
  logo?: string;
  bgColor?: string;
}

export interface Props {
  title?: string;
  items?: CategoryItem[];
  allLabel?: string;
  queryKey?: string; // e.g. 'brand'
  baseHref?: string; // defaults to current path
  active?: string | null; // active slug
  showArrows?: boolean;
  hideTitle?: boolean;
  mobileThreePerView?: boolean;
  mobileTwoColumns?: boolean;
}

const currentLang = getLocale();
const {
  title = currentLang === 'es' ? 'Recetas con tus marcas favoritas' : 'Recipes with your favorite brands',
  items = t('brands', { namespace: 'brands', locale: currentLang }) as unknown as CategoryItem[],
  allLabel = currentLang === 'es' ? 'TODAS' : 'ALL',
  queryKey = 'brand',
  baseHref = Astro.url.pathname,
  active = null,
  showArrows = true,
  hideTitle = false,
  mobileThreePerView = false,
  mobileTwoColumns = false,
}: Props = Astro.props;
---

<div class="content-stretch flex flex-col gap-4 md:gap-8 items-center justify-start w-full py-12" data-query-key={queryKey}>
  <!-- Header Title -->
  {!hideTitle && (
    <div class="text-center">
      <h2 class="text-white text-4xl md:text-6xl font-bold font-['Trois_Mille_TRIAL_Bold'] leading-10">
        {title}
      </h2>
    </div>
  )}

  {mobileThreePerView && (
    <div class="w-full max-w-[1400px] mx-auto md:hidden">
      <div class="cat-mobile-row flex items-center justify-center gap-3 w-full px-3">

        <button class="cat-nav-mobile" type="button" aria-label="Prev" data-dir="-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" />
          </svg>
        </button>

        <div id="cat-scroll-mobile" class="flex-1 overflow-x-scroll scrollbar-hide cat-mobile-scroll">

          {queryKey === 'brand' ? (
            <div class="cat-mobile-item">
              <button
                type="button"
                class="brand-card brand-filter-btn cat-circle-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
                style="--brand-color: #4B5563;"
                data-slug="all"
                aria-label={allLabel}
              >
                <span class="text-white font-bold text-xs text-center">{allLabel}</span>
              </button>
            </div>
          ) : (
            <div class="cat-mobile-item">
              <a
                href={`${baseHref}?${queryKey}=all`}
                class="brand-card brand-filter-btn cat-circle-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
                style="--brand-color: #4B5563;"
                data-slug="all"
              >
                <span class="text-white font-bold text-xs text-center">{allLabel}</span>
              </a>
            </div>
          )}

          {items.map((it: CategoryItem) => (
            queryKey === 'brand' ? (
              <div class="cat-mobile-item">
                <button
                  type="button"
                  class="brand-card brand-filter-btn cat-circle-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
                  style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
                  data-slug={it.slug}
                  aria-label={it.label}
                >
                  {it.logo ? (
                    <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
                  ) : (
                    <span class="text-white font-bold text-xs text-center px-2">{it.label}</span>
                  )}
                </button>
              </div>
            ) : (
              <div class="cat-mobile-item">
                <a
                  href={`${baseHref}?${queryKey}=${it.slug}`}
                  class="brand-card brand-filter-btn cat-circle-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
                  style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
                  data-slug={it.slug}
                >
                  {it.logo ? (
                    <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
                  ) : (
                    <span class="text-white font-bold text-xs text-center px-2">{it.label}</span>
                  )}
                </a>
              </div>
            )
          ))}
        </div>

        <button class="cat-nav-mobile" type="button" aria-label="Next" data-dir="1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </button>

      </div>
    </div>
  )}

  {mobileTwoColumns && (
    <div class="cat-two-col-mobile w-full max-w-sm mx-auto px-6 md:hidden">
      <div class="cat-two-col-grid">
        {queryKey === 'brand' ? (
          <div class="cat-two-col-item">
            <button
              type="button"
              class="brand-card brand-filter-btn cat-two-col-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
              style="--brand-color: #4B5563;"
              data-slug="all"
              aria-label={allLabel}
            >
              <span class="text-white font-bold text-sm text-center">{allLabel}</span>
            </button>
          </div>
        ) : (
          <div class="cat-two-col-item">
            <a
              href={`${baseHref}?${queryKey}=all`}
              class="brand-card brand-filter-btn cat-two-col-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
              style="--brand-color: #4B5563;"
              data-slug="all"
            >
              <span class="text-white font-bold text-sm text-center">{allLabel}</span>
            </a>
          </div>
        )}
        {items.map((it: CategoryItem) => (
          queryKey === 'brand' ? (
            <div class="cat-two-col-item">
              <button
                type="button"
                class="brand-card brand-filter-btn cat-two-col-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
                style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
                data-slug={it.slug}
                aria-label={it.label}
              >
                {it.logo ? (
                  <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
                ) : (
                  <span class="text-white font-bold text-sm text-center px-2">{it.label}</span>
                )}
              </button>
            </div>
          ) : (
            <div class="cat-two-col-item">
              <a
                href={`${baseHref}?${queryKey}=${it.slug}`}
                class="brand-card brand-filter-btn cat-two-col-btn rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
                style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
                data-slug={it.slug}
              >
                {it.logo ? (
                  <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
                ) : (
                  <span class="text-white font-bold text-sm text-center px-2">{it.label}</span>
                )}
              </a>
            </div>
          )
        ))}
      </div>
    </div>
  )}

  <div class={`w-full max-w-[1400px] mx-auto px-4 relative${mobileThreePerView ? ' hidden md:block' : ''}${mobileTwoColumns ? ' hidden md:block' : ''}`}>
    {showArrows && (
      <>
        <button class="nav-btn left-2 md:left-4" type="button" aria-label="Prev" data-dir="-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" />
          </svg>
        </button>
        <button class="nav-btn right-2 md:right-4" type="button" aria-label="Next" data-dir="1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </button>
      </>
    )}

    <div id="cat-scroll" class="flex flex-wrap justify-center pb-6 px-10 md:px-12 lg:px-14" style="gap: clamp(0.4rem, 0.8vw, 1.25rem);">
      <!-- All Button -->
      {queryKey === 'brand' ? (
        <button
          type="button"
          class="brand-card brand-filter-btn cat-desktop-circle rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
          style="--brand-color: #4B5563;"
          data-slug="all"
          aria-label={allLabel}
        >
          <span class="text-white font-bold text-xs md:text-sm lg:text-base text-center">{allLabel}</span>
        </button>
      ) : (
        <a
          href={`${baseHref}?${queryKey}=all`}
          class="brand-card brand-filter-btn cat-desktop-circle rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer bg-gray-600 opacity-100"
          style="--brand-color: #4B5563;"
          data-slug="all"
        >
          <span class="text-white font-bold text-xs md:text-sm lg:text-base text-center">{allLabel}</span>
        </a>
      )}

      {items.map((it: CategoryItem) => (
        queryKey === 'brand' ? (
          <button
            type="button"
            class="brand-card brand-filter-btn cat-desktop-circle rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
            style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
            data-slug={it.slug}
            aria-label={it.label}
          >
            {it.logo ? (
              <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
            ) : (
              <span class="text-white font-bold text-xs md:text-sm lg:text-base text-center px-2">{it.label}</span>
            )}
          </button>
        ) : (
          <a
            href={`${baseHref}?${queryKey}=${it.slug}`}
            class="brand-card brand-filter-btn cat-desktop-circle rounded-full overflow-hidden shadow-lg flex items-center justify-center hover:scale-105 transition-all duration-300 cursor-pointer"
            style={`background-color: ${it.bgColor ?? '#E5E7EB'}; --brand-color: ${it.bgColor ?? '#E5E7EB'};`}
            data-slug={it.slug}
          >
            {it.logo ? (
              <img src={it.logo} alt={it.label} class="w-[65%] h-[65%] object-contain" loading="lazy" />
            ) : (
              <span class="text-white font-bold text-xs md:text-sm lg:text-base text-center px-2">{it.label}</span>
            )}
          </a>
        )
      ))}
    </div>
  </div>
</div>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  /* Smooth scrolling behavior */
  .scrollbar-hide {
    scroll-behavior: smooth;
  }

  /* Enhance touch scrolling on iOS and modern browsers */
  #cat-scroll {
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    overscroll-behavior-x: contain;
    cursor: grab;
  }
  #cat-scroll.dragging {
    cursor: grabbing;
    user-select: none;
  }

  .brand-card{
    margin-top: 12px;
    aspect-ratio: 1 / 1;
    border-radius: 50% !important;
  }

  /* Brand card hover effect */
  .brand-card:hover {
    border: 4px solid var(--brand-color);
    box-shadow: 0 8px 25px -5px color-mix(in srgb, var(--brand-color) 30%, transparent);
    background-color: color-mix(in srgb, var(--brand-color) 80%, black 20%) !important;
  }

  /* SOLO el activo se hace más grande - SIN transparencias */
  .brand-card.active {
    border: 4px solid var(--brand-color);
    box-shadow: 0 8px 25px -5px color-mix(in srgb, var(--brand-color) 50%, transparent);
    transform: scale(1.15);
  }
  
  /* Los demás sin cambios - mantienen su apariencia normal */
  .brand-card:not(.active) {
    /* Sin cambios de opacidad - se ven normales */
  }
  /* Desktop circles: responsive sizing with clamp */
  .cat-desktop-circle {
    width: clamp(60px, 6.5vw, 110px);
    height: clamp(60px, 6.5vw, 110px);
    aspect-ratio: 1 / 1;
    flex-shrink: 1;
  }

  .nav-btn {
    display: none;
  }
  .nav-btn:hover {
    background: rgba(255,255,255,1);
    transform: translateY(-50%) scale(1.1);
    box-shadow: 0 12px 30px -5px rgba(0,0,0,0.35);
  }
  @media (min-width: 1024px) {
    .nav-btn {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      background: rgba(255,255,255,0.95);
      color: #111827;
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 9999px;
      display: grid;
      place-items: center;
      font-size: 1.25rem;
      line-height: 1;
      box-shadow: 0 12px 30px -5px rgba(0,0,0,0.25);
      transition: all 0.2s ease;
      pointer-events: auto;
    }

    .nav-btn.left-2 { left: -56px; }
    .nav-btn.right-2 { right: -56px; }

    @media (min-width: 1400px) {
      .nav-btn.left-2 { left: -72px; }
      .nav-btn.right-2 { right: -72px; }
      .nav-btn { width: 3rem; height: 3rem; }
    }
  }

  /* ── Mobile carousel ── */
  .cat-mobile-scroll {
    --cat-size: 80px;
    --cat-gap: 12px;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: var(--cat-size);
    column-gap: var(--cat-gap);
    padding: 0;
    flex: 0 0 calc((var(--cat-size) + var(--cat-gap)) * 3);
    width: calc((var(--cat-size) + var(--cat-gap)) * 3);
    margin: 0 auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    cursor: default;
  }
  .cat-mobile-row {
    gap: 8px;
  }

  .cat-mobile-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    scroll-snap-align: start;
  }

  .cat-mobile-item .brand-card {
    margin-top: 0;
    width: 100%;
    box-shadow: none !important;
  }
  .cat-mobile-item .brand-card:hover {
    box-shadow: none !important;
  }

  /* Mobile brand circle: fixed 80px to match product `brand-card` (w-20 = 80px) */
  .cat-circle-btn {
    width: 80px;
    max-width: 80px;
    margin-left: auto;
    margin-right: auto;
    aspect-ratio: 1 / 1 !important;
    border-radius: 50% !important;
    box-shadow: none !important;
  }

  .cat-nav-mobile {
    min-width: 2rem;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.95);
    color: #111827;
    display: grid;
    place-items: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    flex-shrink: 0;
  }
  .cat-nav-mobile:hover {
    background: rgba(255, 255, 255, 1);
    transform: scale(1.1);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  }

  /* ── Botones en marcas a dos columnas mobile */
  .cat-two-col-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    justify-items: center;
    align-items: center;
  }

  /* If total items are odd, last item spans full width and centers */
  .cat-two-col-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
  }

  .cat-two-col-item {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .cat-two-col-btn {
    width: 130px;
    height: 130px;
    aspect-ratio: 1 / 1 !important;
    border-radius: 50% !important;
    transform: none !important;
    margin-top: 0 !important;
  }

  /* Override mobile scale for two-col buttons */
  @media (max-width: 767px) {
    .cat-two-col-btn,
    .cat-two-col-btn:hover {
      transform: none !important;
    }
    .cat-two-col-btn.active {
      transform: none !important;
      outline: 4px solid var(--brand-color);
      outline-offset: 0px;
      box-shadow: 0 8px 25px -5px color-mix(in srgb, var(--brand-color) 50%, transparent) !important;
      background-color: color-mix(in srgb, var(--brand-color) 80%, black 20%) !important;
    }
  }

  /* Mobile-only: evitar que los botones cambien de tamaño al activarse.
     En móvil mostramos una orilla del mismo color usando `outline` para
     no alterar el tamaño del botón (outline no afecta box-sizing). */
  @media (max-width: 767px) {

    .brand-card,
    .brand-card:hover,
    .cat-circle-btn,
    .cat-circle-btn:hover {
      transform: scale(0.85) !important;
    }

    .brand-card.active {
      transform: scale(0.85) !important;
      outline: 4px solid var(--brand-color);
      outline-offset: 0px;
      box-shadow: 0 8px 25px -5px color-mix(in srgb, var(--brand-color) 50%, transparent) !important;
      background-color: color-mix(in srgb, var(--brand-color) 80%, black 20%) !important;
    }

    .brand-card:hover {
      border: none !important;
      box-shadow: none !important;
    }
  }
</style>

<script>
  function initCategoriesCarousel() {
    const container = document.querySelector('[data-query-key]');
    if (!container) return;

    const queryKey = container.getAttribute('data-query-key') || 'brand';
    const scroll = container.querySelector('#cat-scroll');
    const buttons = container.querySelectorAll('.brand-filter-btn');
    const navBtns = container.querySelectorAll('.nav-btn');

    if (!scroll || !buttons.length) return;

    // Ocultar flechas si todo el contenido cabe sin scroll
    function updateNavVisibility() {
      const needsScroll = scroll.scrollWidth > scroll.clientWidth + 2;
      navBtns.forEach(btn => {
        (btn as HTMLElement).style.display = needsScroll ? '' : 'none';
      });
    }
    updateNavVisibility();
    window.addEventListener('resize', updateNavVisibility);

    // Desktop/Tablet: navegación con flechas absolutas
    navBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const dir = parseInt(btn.getAttribute('data-dir') || '1');
        const scrollAmount = scroll.clientWidth * 0.6;
        scroll.scrollBy({ left: dir * scrollAmount, behavior: 'smooth' });
      });
    });

    const mobileNavBtns = container.querySelectorAll('.cat-nav-mobile');
    const mobileScrollEl = container.querySelector('#cat-scroll-mobile');
    if (mobileScrollEl && mobileNavBtns.length) {
      mobileNavBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const dir = parseInt(btn.getAttribute('data-dir') || '1');
          const itemWidth = (mobileScrollEl as HTMLElement).clientWidth / 3;
          (mobileScrollEl as HTMLElement).scrollBy({ left: dir * itemWidth, behavior: 'smooth' });
        });
      });
    }

    // Drag to scroll
    let isDown = false;
    let startX: number;
    let scrollLeft: number;

    scroll.addEventListener('mousedown', (e: Event) => {
      const me = e as MouseEvent;
      isDown = true;
      scroll.classList.add('dragging');
      startX = me.pageX - (scroll as HTMLElement).offsetLeft;
      scrollLeft = scroll.scrollLeft;
    });

    scroll.addEventListener('mouseleave', () => {
      isDown = false;
      scroll.classList.remove('dragging');
    });

    scroll.addEventListener('mouseup', () => {
      isDown = false;
      scroll.classList.remove('dragging');
    });

    scroll.addEventListener('mousemove', (e: Event) => {
      if (!isDown) return;
      e.preventDefault();
      const me = e as MouseEvent;
      const x = me.pageX - (scroll as HTMLElement).offsetLeft;
      const walk = (x - startX) * 2;
      scroll.scrollLeft = scrollLeft - walk;
    });

    // Click en botones de filtro
    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const slug = btn.getAttribute('data-slug') || 'all';
        
        // Actualizar clase activa
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Actualizar URL
        const url = new URL(window.location.href);
        if (slug === 'all') {
          url.searchParams.delete(queryKey);
        } else {
          url.searchParams.set(queryKey, slug);
        }
        history.pushState({}, '', url.toString());

        // Disparar evento de filtro
        const event = new CustomEvent('brandFilterChange', { 
          detail: { brand: slug, queryKey } 
        });
        document.dispatchEvent(event);

        // Guardar en sessionStorage
        try { 
          sessionStorage.setItem('selectedBrand', slug); 
        } catch {}
      });
    });

    // Aplicar estado inicial desde URL
    const urlParams = new URLSearchParams(window.location.search);
    const activeBrand = urlParams.get(queryKey) || 'all';
    
    buttons.forEach(btn => {
      const slug = btn.getAttribute('data-slug');
      if (slug === activeBrand) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  // Inicializar en diferentes eventos
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoriesCarousel);
  } else {
    initCategoriesCarousel();
  }
  
  document.addEventListener('astro:page-load', initCategoriesCarousel);
  document.addEventListener('astro:after-swap', initCategoriesCarousel);
</script>