---
import { getLocale } from '../../i18n/i18n';
import RecipeCard from './RecipeCard.astro';

interface RecipeItem {
  id: string;
  title: string;
  image?: string;
  preparation_time: number;
  difficulty?: string;
  servings?: number;
  rating?: number;
  video?: string;
}

export interface Props {
  items: RecipeItem[];
}

const { items = [] } = Astro.props as { items: RecipeItem[] };
const currentLang = getLocale();
---

{items.length === 0 ? (
  <div class="w-full text-center text-gray-500 py-8">
    {currentLang === 'es' ? 'No hay recetas relacionadas.' : 'No related recipes.'}
  </div>
) : (
  <div class="w-full relative" data-related-recipes-carousel>
    <!-- Margin creates space for buttons; overflow-hidden has NO padding -->
    <div class="overflow-hidden relative mx-10 md:mx-12 lg:mx-14">
      <div id="relatedTrack" class="flex gap-4 md:gap-6 transition-transform duration-300 will-change-transform">
        {items.map((recipe) => (
          <div class="w-full md:w-[calc((100%-16px)/2)] lg:w-[calc((100%-48px)/3)] flex-shrink-0 min-w-0">
            <RecipeCard
              image={recipe.image || 'https://snack.yummiespromociones.com/SnacksyummiesAssets/placeholder.webp'}
              title={recipe.title}
              time={`${recipe.preparation_time}MIN`}
              id={recipe.id}
              textColor="text-white"
              iconColor="text-white"
              video={recipe.video}
            />
          </div>
        ))}
      </div>
    </div>
    <!-- Bottones de navecacion para recetas -->
    <div class="w-full mx-10 md:mx-12 lg:mx-14 mt-6">
      <div class="flex justify-between items-center">
        <button id="relPrev" class="rel-nav-btn text-white font-bold bg-transparent hover:opacity-90 px-4 py-2 rounded-full shadow transition-colors duration-150" aria-label={currentLang === 'es' ? 'Receta anterior' : 'Previous recipe'}>
          {currentLang === 'es' ? 'Receta anterior' : 'Previous recipe'}
        </button>
        <button id="relNext" class="rel-nav-btn text-white font-bold bg-transparent hover:opacity-90 px-4 py-2 rounded-full shadow transition-colors duration-150" aria-label={currentLang === 'es' ? 'Siguiente receta' : 'Next recipe'}>
          {currentLang === 'es' ? 'Siguiente receta' : 'Next recipe'}
        </button>
      </div>
    </div>
  </div>
)}

<script>
  function initRelatedCarousel(root: any) {
    if (!root || root._relInit) return;
    root._relInit = true;

    const track = root.querySelector('#relatedTrack');
    const prev = root.querySelector('#relPrev');
    const next = root.querySelector('#relNext');

    let currentTranslate = 0;

    function getStep() {
      const firstCard = track?.firstElementChild;
      if (!firstCard) return 400;
      const style = window.getComputedStyle(track);
      const gap = parseInt(style.gap) || 16;
      return firstCard.getBoundingClientRect().width + gap;
    }

    function getMaxTranslate() {
      const container = track?.parentElement;
      if (!container) return 0;
      return Math.max(0, track.scrollWidth - container.clientWidth);
    }

    function getVisibleCount() {
      const step = getStep();
      if (!step) return 1;
      const container = track?.parentElement;
      if (!container) return 1;
      return Math.max(1, Math.floor(container.clientWidth / step));
    }

    function update() {
      if (!track) return;
      const maxTranslate = getMaxTranslate();
      const visibleCount = getVisibleCount();

      currentTranslate = Math.min(currentTranslate, maxTranslate);
      currentTranslate = Math.max(0, currentTranslate);

      if (track.children.length <= visibleCount) {
        track.style.transform = 'translateX(0)';
        track.style.justifyContent = 'center';
      } else {
        track.style.justifyContent = 'flex-start';
        track.style.transform = `translateX(-${currentTranslate}px)`;
      }

      const atStart = currentTranslate <= 0;
      const atEnd = currentTranslate >= maxTranslate - 1;

      if (prev) {
        prev.style.opacity = atStart ? '0.4' : '1';
        prev.style.pointerEvents = atStart ? 'none' : 'auto';
      }
      if (next) {
        next.style.opacity = atEnd ? '0.4' : '1';
        next.style.pointerEvents = atEnd ? 'none' : 'auto';
      }
    }

    if (track && prev && next) {
      prev.addEventListener('click', () => {
        const step = getStep();
        currentTranslate = Math.max(0, currentTranslate - step);
        update();
      });
      next.addEventListener('click', () => {
        const step = getStep();
        const maxTranslate = getMaxTranslate();
        currentTranslate = Math.min(maxTranslate, currentTranslate + step);
        update();
      });
      window.addEventListener('resize', () => {
        update();
      });
      update();
    }
  }

  function initAll() {
    document.querySelectorAll('[data-related-recipes-carousel]').forEach((el) => initRelatedCarousel(el as any));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
  document.addEventListener('astro:page-load', initAll);
  document.addEventListener('astro:after-swap', initAll);
</script>
    <!-- estilo para botones de las recetas -->
<style>
  .rel-nav-btn {
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.06);
    color: #ffffff;
    cursor: pointer;
  }

  .rel-nav-btn {
    min-width: 160px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 18px;
    white-space: nowrap;
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .rel-nav-btn {
      transform: none !important;
    }
    .rel-nav-btn:hover {
      transform: none !important;
      background: rgba(255,255,255,0.12);
    }
  }

  @media (max-width: 480px) {
    .rel-nav-btn {
      min-width: 140px;
      height: 40px;
      font-size: 0.9rem;
      padding: 0 12px;
    }
  }

  .rel-nav-btn:focus,
  .rel-nav-btn.active {
    outline: none;
    background: #ffffff;
    color: #0A3D7E;
    border-color: #0A3D7E;
    box-shadow: 0 8px 24px rgba(10,61,126,0.12);
  }
</style>
