---
// src/components/common/WinnersCarousel/WinnersCarousel.astro
import LazyImage from '../LazyImage.astro';

export interface Props {
  country: string;
  winners: Array<{
    image: string;
    image_mobile?: string;
    description: string;
  }>;
  currentLang: 'es' | 'en';
  uiTexts?: {
    winnerLabel?: string;
  };
}

const { country, winners, currentLang, uiTexts } = Astro.props;

// Ensure we have winners data
const displayWinners = winners || [];
const totalSlides = displayWinners.length; // one card per slide for consistent responsive behavior
const openLabel = currentLang === 'es' ? 'Abrir ganador' : 'Open winner';
const closeLabel = currentLang === 'es' ? 'Cerrar vista' : 'Close preview';
const previewLabel = currentLang === 'es' ? 'Vista ampliada' : 'Expanded view';
---

<div class="winners-carousel" data-country={country}>
  <!-- Country Title -->
  <div class="mb-8">
    <h2 class="font-bold text-white text-[56px] leading-[56px] font-['Trois_Mille_TRIAL_Bold'] mb-0">
      {country}
    </h2>
  </div>

  <!-- Carousel Container -->
  <div class="flex flex-col gap-6 items-center justify-center w-full">
    <!-- Photo Cards Container -->
    <div class="carousel-container relative w-full overflow-hidden">
      <div class="carousel-track flex transition-transform duration-300 ease-in-out" data-slides={totalSlides}>
        {displayWinners.map((winner, index) => (
          <div class="carousel-slide flex justify-center items-center min-w-full">
            <div class="winner-card flex flex-col items-start justify-start relative w-[265px] flex-shrink-0">
              <button
                type="button"
                class="winner-card-trigger bg-[#faf1e9] flex flex-col gap-4 items-center justify-start overflow-hidden p-4 rounded-[20px] w-full relative text-left transition-transform duration-300 hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#ffd53d]/70"
                data-winner-image={winner.image}
                data-winner-image-mobile={winner.image_mobile || winner.image}
                data-winner-description={winner.description}
                data-winner-country={country}
                data-winner-rank={index + 1}
                aria-label={`${openLabel}: ${winner.description}`}
              >
                <!-- imagen ganador -->
                <div class="winner-card-image h-[250px] w-full rounded-lg overflow-hidden shadow-[0_10px_24px_rgba(17,68,142,0.18)]">
                  <picture class="block w-full h-full">
                    {winner.image_mobile && (
                      <source media="(max-width: 767px)" srcset={winner.image_mobile} />
                    )}
                    <img
                      src={winner.image}
                      alt={winner.description}
                      class="w-full h-full object-cover object-center"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                </div>

                <!-- Description Container -->
                <div class="flex flex-col items-center justify-start py-4 w-full">
                  <div class="font-['Trois_Mille_TRIAL_Medium'] text-[#11448e] text-[18px] leading-[20px] text-center w-[189px] font-medium">
                    <p>{winner.description}</p>
                  </div>
                </div>
              </button>

              <!-- logo ganador -->
              <div class="absolute left-[-35px] top-[-32px] w-[70px] h-[65px] z-10">
                <svg xmlns="http://www.w3.org/2000/svg" width="70" height="65" viewBox="0 0 70 65" fill="none" class="w-full h-full">
                  <path d="M52.1367 5.02148C53.3055 4.50763 54.4798 4.55138 55.4043 4.8252C57.1511 5.34267 58.6206 6.8462 58.96 8.85059L59.0293 9.2627C61.0896 19.1624 63.092 28.7881 65.1543 38.6973H65.1523C65.2973 39.3574 65.3286 39.9782 65.3018 40.5342L65.3037 40.5352C65.3031 40.5502 65.3005 40.5651 65.2998 40.5801C65.2992 40.5921 65.3005 40.6042 65.2998 40.6162L65.2979 40.6152C65.2489 41.5945 65.0009 42.5234 64.6094 43.3564L64.6104 43.3574C61.7312 49.4873 55.8032 54.1708 49.5439 57.0234C43.2729 59.8814 35.9446 61.2364 29.6992 59.9512L29.6611 59.9434L29.623 59.9346C29.1375 59.8248 28.6262 59.6459 28.124 59.3818V59.3838C28.1125 59.3778 28.1013 59.3712 28.0898 59.3652C28.0727 59.3561 28.0552 59.3473 28.0381 59.3379V59.3359C27.2778 58.9267 26.7193 58.4023 26.3379 57.9688L26.3311 57.96L26.3232 57.9512C23.6061 54.8272 10.8722 39.7411 5.99023 33.7832L5.99121 33.7822C4.73947 32.2551 4.4631 30.1784 5.2666 28.4316C5.6713 27.5519 6.39306 26.683 7.47168 26.1484C8.57094 25.6037 9.77775 25.5387 10.8652 25.8447C16.0476 27.2852 18.8338 28.5099 22.8857 29.1816C22.9453 28.8357 22.9926 28.3973 23.0264 27.834C23.2124 23.905 22.9037 20.1659 22.7588 15.7607V15.7598C22.6991 14.3905 22.6475 13.0398 22.5967 11.666C22.5228 9.66596 23.5379 7.65507 25.5303 6.71289C27.5065 5.7785 29.6786 6.25668 31.1758 7.54102L31.1768 7.54004C37.8332 13.2208 39.8693 15.5432 44.4639 18.7051C44.563 18.7714 44.6516 18.8273 44.7305 18.874C44.8409 18.7015 44.9778 18.474 45.1348 18.1729C45.5143 17.4449 45.8235 16.7213 46.291 15.7129C47.2163 13.5747 48.442 10.4557 49.6621 7.56348C50.1006 6.52385 50.9208 5.55607 52.1367 5.02148ZM12.1777 28.7129C12.1826 28.7188 12.1875 28.7246 12.1924 28.7305L12.1768 28.71L12.1777 28.7129Z" fill="#D23627" stroke="#FAF1E9" stroke-width="8"/>
                  <text x="35" y="30" text-anchor="middle" dominant-baseline="central" class="fill-white font-bold text-sm font-['Trois_Mille_TRIAL_Bold']">{index + 1}</text>
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Carousel Navigation -->
    {totalSlides > 1 && (
      <div class="carousel-nav flex gap-6 items-center justify-center">
        <!-- Previous Button -->
        <button 
          class="carousel-prev w-8 h-8 flex items-center justify-center text-white hover:text-gray-300 transition-colors cursor-pointer"
          aria-label="Previous slide"
        >
          <svg class="w-full h-full" viewBox="0 0 32 32" fill="none">
            <path d="M20 8L12 16L20 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Navigation Dots -->
        <div class="nav-dots flex items-center justify-center">
          {Array.from({ length: totalSlides }, (_, index) => (
            <div class="nav-dot relative w-10 h-10 flex items-center justify-center cursor-pointer">
              <div 
                class={`dot w-4 h-4 rounded-full transition-colors ${index === 0 ? 'bg-white' : 'bg-[#a4aeb7]'}`}
                data-slide={index}
              ></div>
            </div>
          ))}
        </div>

        <!-- Next Button -->
        <button 
          class="carousel-next w-8 h-8 flex items-center justify-center text-white hover:text-gray-300 transition-colors cursor-pointer"
          aria-label="Next slide"
        >
          <svg class="w-full h-full" viewBox="0 0 32 32" fill="none">
            <path d="M12 8L20 16L12 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    )}
  </div>

  <div class="winner-lightbox fixed inset-0 z-[120] hidden items-center justify-center p-4 md:p-8" aria-hidden="true">
    <div class="winner-lightbox-backdrop absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(57,165,255,0.35),_rgba(6,23,52,0.92)_58%)] backdrop-blur-md"></div>
    <div class="winner-lightbox-panel relative z-10 flex max-h-[92vh] w-full max-w-5xl flex-col overflow-hidden rounded-[28px] border border-white/20 bg-[#faf1e9] shadow-[0_30px_80px_rgba(3,15,40,0.55)]">
      <div class="winner-lightbox-confetti pointer-events-none absolute inset-x-0 top-0 z-10 h-24 overflow-hidden" aria-hidden="true">
        <span class="confetti-piece confetti-piece-red"></span>
        <span class="confetti-piece confetti-piece-yellow"></span>
        <span class="confetti-piece confetti-piece-blue"></span>
        <span class="confetti-piece confetti-piece-cyan"></span>
        <span class="confetti-piece confetti-piece-red confetti-piece-wide"></span>
        <span class="confetti-piece confetti-piece-yellow confetti-piece-wide"></span>
      </div>
      <button
        type="button"
        class="winner-lightbox-close absolute right-4 top-4 z-20 flex h-11 w-11 items-center justify-center rounded-full border border-[#11448e]/10 bg-white/90 text-[#11448e] shadow-[0_10px_24px_rgba(17,68,142,0.18)] transition-transform duration-200 hover:scale-105 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#ffd53d]/70"
        aria-label={closeLabel}
      >
        <span class="text-2xl leading-none">&times;</span>
      </button>

      <div class="grid max-h-[92vh] grid-cols-1 overflow-auto md:grid-cols-[minmax(0,1.85fr)_minmax(280px,0.75fr)]">
        <div class="winner-lightbox-media relative bg-[linear-gradient(180deg,#1d6daf_0%,#11448e_100%)] p-0">
          <picture class="block h-full min-h-[320px] overflow-hidden bg-[#11448e] md:min-h-[500px]">
            <source class="winner-lightbox-source" media="(max-width: 767px)" srcset="" />
            <img class="winner-lightbox-image h-full w-full object-cover object-center" src="" alt={previewLabel} />
          </picture>
        </div>

        <div class="flex flex-col gap-6 bg-[#faf1e9] p-6 md:p-8">
          <div class="space-y-4">
            <div class="inline-flex w-fit items-center gap-2 rounded-full bg-[#d23627] px-4 py-2 text-[12px] font-bold uppercase tracking-[0.12em] text-white shadow-[0_10px_24px_rgba(210,54,39,0.24)]">
              <span class="winner-lightbox-rank"></span>
            </div>
            <div class="space-y-2">
              <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#2ca8ff]">
                {currentLang === 'es' ? 'Ganadores Yummies' : 'Yummies Winners'}
              </p>
              <h3 class="winner-lightbox-country font-['Trois_Mille_TRIAL_Bold'] text-3xl leading-tight text-[#11448e] md:text-4xl"></h3>
              <p class="winner-lightbox-description font-['Trois_Mille_TRIAL_Medium'] text-lg leading-7 text-[#11448e]/85"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .winners-carousel {
    width: 100%;
  }

  .carousel-container {
    width: 100%;
  }

  .carousel-track {
    width: 100%;
  }

  .carousel-slide {
    width: 100%;
    justify-content: center;
  }

  .winner-card-trigger {
    cursor: pointer;
  }

  .winner-card-trigger:hover .winner-card-image,
  .winner-card-trigger:focus-visible .winner-card-image {
    transform: scale(1.03);
    box-shadow: 0 18px 36px rgba(17, 68, 142, 0.24);
  }

  .winner-card-image {
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .winner-lightbox.is-open {
    display: flex;
  }

  .winner-lightbox-panel {
    transform: translateY(18px) scale(0.97);
    opacity: 0;
    transition: transform 220ms ease, opacity 220ms ease;
  }

  .winner-lightbox.is-open .winner-lightbox-panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .confetti-piece {
    position: absolute;
    top: -18px;
    width: 6px;
    height: 20px;
    border-radius: 2px;
    opacity: 0.85;
    animation: lightbox-confetti-fall 1.9s linear infinite;
  }

  .confetti-piece-wide {
    width: 12px;
    height: 5px;
    border-radius: 2px;
  }

  .confetti-piece:nth-child(1) { left: 12%; animation-delay: -0.2s; transform: rotate(18deg); }
  .confetti-piece:nth-child(2) { left: 28%; animation-delay: -1.2s; transform: rotate(-12deg); }
  .confetti-piece:nth-child(3) { left: 46%; animation-delay: -2.1s; transform: rotate(22deg); }
  .confetti-piece:nth-child(4) { left: 63%; animation-delay: -0.8s; transform: rotate(-20deg); }
  .confetti-piece:nth-child(5) { left: 79%; animation-delay: -1.7s; transform: rotate(14deg); }
  .confetti-piece:nth-child(6) { left: 88%; animation-delay: -2.8s; transform: rotate(-16deg); }

  .confetti-piece-red { background: #d23627; }
  .confetti-piece-yellow { background: #ffd53d; }
  .confetti-piece-blue { background: #11448e; }
  .confetti-piece-cyan { background: #2ca8ff; }

  @keyframes lightbox-confetti-fall {
    0% {
      transform: translate3d(0, -18px, 0) rotate(0deg);
      opacity: 0;
    }
    15% {
      opacity: 0.9;
    }
    100% {
      transform: translate3d(18px, 106px, 0) rotate(240deg);
      opacity: 0;
    }
  }

  /* Custom font loading */
  @font-face {
    font-family: 'Trois_Mille_TRIAL_Bold';
    src: url('/src/assets/fonts/TroisMilleBold.otf') format('opentype');
    font-weight: 700;
    font-display: swap;
  }

  @font-face {
    font-family: 'Trois_Mille_TRIAL_Medium';
    src: url('/src/assets/fonts/TroisMilleTRIALRglr23.otf') format('opentype');
    font-weight: 550;
    font-display: swap;
  }

  /* Responsive adjustments */
  @media (max-width: 1200px) {
    .carousel-slide {
      gap: 1rem;
    }
    
    .winner-card {
      width: calc(25% - 0.75rem);
      min-width: 240px;
    }
  }

  @media (max-width: 768px) {
    .carousel-slide {
      flex-wrap: wrap;
      justify-content: center;
    }
    
    .winner-card {
      width: calc(50% - 0.5rem);
      min-width: 200px;
    }

    .winner-lightbox-panel {
      border-radius: 24px;
    }

    .winner-card-image {
      height: 236px;
    }
  }

  @media (max-width: 480px) {
    .winner-card {
      width: 100%;
      max-width: 265px;
    }

    .winner-lightbox {
      padding: 1rem;
    }

    .winner-lightbox-media {
      padding: 0;
    }

    .winner-card-image {
      height: 228px;
    }

    .winner-lightbox-image {
      object-fit: cover;
    }
  }
</style>

<script>
  (() => {
    type Cleanup = () => void;

    declare global {
      interface Window {
        __winnersCarouselCleanups?: Cleanup[];
        __winnersCarouselEventsRegistered?: boolean;
      }
    }

    function runCleanups() {
      window.__winnersCarouselCleanups?.forEach((cleanup) => cleanup());
      window.__winnersCarouselCleanups = [];
      document.body.style.overflow = '';
    }

    function initWinnersCarousel() {
      runCleanups();

      const cleanups: Cleanup[] = [];
      const carousels = document.querySelectorAll('.winners-carousel');

      carousels.forEach((carousel) => {
        const track = carousel.querySelector('.carousel-track');
        const carouselContainer = carousel.querySelector('.carousel-container');
        const slides = carousel.querySelectorAll('.carousel-slide');
        let containerWidth = carouselContainer instanceof HTMLElement ? Math.round(carouselContainer.clientWidth) : Math.round(carousel.clientWidth);
        const prevBtn = carousel.querySelector('.carousel-prev');
        const nextBtn = carousel.querySelector('.carousel-next');
        const dots = carousel.querySelectorAll('.nav-dot');
        const lightbox = carousel.querySelector('.winner-lightbox');
        const lightboxImage = lightbox?.querySelector('.winner-lightbox-image');
        const lightboxSource = lightbox?.querySelector('.winner-lightbox-source');
        const lightboxDescription = lightbox?.querySelector('.winner-lightbox-description');
        const lightboxCountry = lightbox?.querySelector('.winner-lightbox-country');
        const lightboxRank = lightbox?.querySelector('.winner-lightbox-rank');
        const lightboxClose = lightbox?.querySelector('.winner-lightbox-close');
        const triggers = carousel.querySelectorAll('.winner-card-trigger');
        let currentSlide = 0;
        const totalSlides = slides.length;

        function openLightbox(trigger: Element) {
          if (!(lightbox instanceof HTMLElement)) return;
          if (!(lightboxImage instanceof HTMLImageElement)) return;

          const desktopImage = trigger.getAttribute('data-winner-image') || '';
          const mobileImage = trigger.getAttribute('data-winner-image-mobile') || desktopImage;
          const description = trigger.getAttribute('data-winner-description') || '';
          const winnerCountry = trigger.getAttribute('data-winner-country') || '';
          const winnerRank = trigger.getAttribute('data-winner-rank') || '';

          lightboxImage.src = desktopImage;
          lightboxImage.alt = description;

          if (lightboxSource instanceof HTMLSourceElement) {
            lightboxSource.srcset = mobileImage;
          }

          if (lightboxDescription instanceof HTMLElement) {
            lightboxDescription.textContent = description;
          }

          if (lightboxCountry instanceof HTMLElement) {
            lightboxCountry.textContent = winnerCountry;
          }

          if (lightboxRank instanceof HTMLElement) {
            lightboxRank.textContent = `#${winnerRank}`;
          }

          lightbox.classList.add('is-open');
          lightbox.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
          if (!(lightbox instanceof HTMLElement)) return;

          lightbox.classList.remove('is-open');
          lightbox.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }

        triggers.forEach((trigger) => {
          const handleClick = () => openLightbox(trigger);
          trigger.addEventListener('click', handleClick);
          cleanups.push(() => trigger.removeEventListener('click', handleClick));
        });

        if (lightboxClose instanceof HTMLElement) {
          lightboxClose.addEventListener('click', closeLightbox);
          cleanups.push(() => lightboxClose.removeEventListener('click', closeLightbox));
        }

        if (lightbox instanceof HTMLElement) {
          const handleBackdropClick = (event: Event) => {
            if (event.target === lightbox || (event.target instanceof HTMLElement && event.target.classList.contains('winner-lightbox-backdrop'))) {
              closeLightbox();
            }
          };

          lightbox.addEventListener('click', handleBackdropClick);
          cleanups.push(() => lightbox.removeEventListener('click', handleBackdropClick));
        }

        const handleEscape = (event: KeyboardEvent) => {
          if (event.key === 'Escape' && lightbox instanceof HTMLElement && lightbox.classList.contains('is-open')) {
            closeLightbox();
          }
        };

        document.addEventListener('keydown', handleEscape);
        cleanups.push(() => document.removeEventListener('keydown', handleEscape));
        cleanups.push(closeLightbox);

        if (totalSlides <= 1 || !(track instanceof HTMLElement)) {
          return;
        }

        // ensure track and slides use pixel widths to avoid fractional-pixel peeking
        function setSlideWidths(){
          containerWidth = carouselContainer instanceof HTMLElement ? Math.round(carouselContainer.clientWidth) : Math.round(carousel.clientWidth);
          containerWidth = Math.max(0, containerWidth);
          track.style.width = `${slides.length * containerWidth}px`;
          track.style.gap = '0px';
          slides.forEach((sl) => {
            if (sl instanceof HTMLElement) {
              sl.style.boxSizing = 'border-box';
              sl.style.flex = `0 0 ${containerWidth}px`;
              sl.style.width = `${containerWidth}px`;
              sl.style.margin = '0';
              sl.style.padding = '0';
            }
          });
        }
        setSlideWidths();
        let resizeTimer;
        const resizeHandler = () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(() => { setSlideWidths(); updateCarousel(true); }, 80); };
        window.addEventListener('resize', resizeHandler);
        cleanups.push(() => window.removeEventListener('resize', resizeHandler));

        function updateCarousel(skipFade = false) {
          const translateX = -currentSlide * containerWidth;
          const doSnap = () => {
            if (track instanceof HTMLElement) {
              track.style.transition = 'none';
              track.style.transform = `translateX(${translateX}px)`;
            }
            dots.forEach((dot, index) => {
              const dotElement = dot.querySelector('.dot');
              if (dotElement instanceof HTMLElement) {
                dotElement.className = index === currentSlide
                  ? 'dot w-4 h-4 rounded-full transition-colors bg-white'
                  : 'dot w-4 h-4 rounded-full transition-colors bg-[#a4aeb7]';
              }
            });
          };
          if (skipFade || !(carouselContainer instanceof HTMLElement)) {
            doSnap();
            return;
          }
          carouselContainer.style.transition = 'opacity 220ms ease';
          carouselContainer.style.opacity = '0';
          setTimeout(() => {
            doSnap();
            requestAnimationFrame(() => {
              carouselContainer.style.opacity = '1';
            });
          }, 220);
        }

        function prevSlide() {
          currentSlide = currentSlide === 0 ? totalSlides - 1 : currentSlide - 1;
          updateCarousel();
        }

        function nextSlide() {
          currentSlide = currentSlide === totalSlides - 1 ? 0 : currentSlide + 1;
          updateCarousel();
        }

        function goToSlide(slideIndex: number) {
          currentSlide = slideIndex;
          updateCarousel();
        }

        if (prevBtn instanceof HTMLElement) {
          prevBtn.addEventListener('click', prevSlide);
          cleanups.push(() => prevBtn.removeEventListener('click', prevSlide));
        }

        if (nextBtn instanceof HTMLElement) {
          nextBtn.addEventListener('click', nextSlide);
          cleanups.push(() => nextBtn.removeEventListener('click', nextSlide));
        }

        dots.forEach((dot, index) => {
          const handleDotClick = () => goToSlide(index);
          dot.addEventListener('click', handleDotClick);
          cleanups.push(() => dot.removeEventListener('click', handleDotClick));
        });

        const autoplay = window.setInterval(nextSlide, 5000);
        cleanups.push(() => window.clearInterval(autoplay));

        updateCarousel(true);
      });

      window.__winnersCarouselCleanups = cleanups;
    }

    initWinnersCarousel();

    if (!window.__winnersCarouselEventsRegistered) {
      window.__winnersCarouselEventsRegistered = true;
      document.addEventListener('astro:page-load', initWinnersCarousel);
      document.addEventListener('astro:after-swap', initWinnersCarousel);
    }
  })();
</script>
