---
import SocialShare from '../common/SocialShare.astro';

interface Props {
  items: any[];
  currentLang: string;
  isFinished?: boolean;
}

const { 
  items = [],
  currentLang,
  isFinished = false
} = Astro.props;

const uid = `promos-${Math.random().toString(36).slice(2)}`;

const formattedDate = (startDate: string, endDate: string) => {
  const start = new Date(startDate).toLocaleDateString(currentLang);
  const end = new Date(endDate).toLocaleDateString(currentLang);
  return `${start} - ${end}`;
};
---

<div class="promos-carousel" id={uid}>
  <div class="promo-carousel-container content-stretch flex flex-col gap-6 items-center justify-start relative w-full">
    <div class="content-stretch flex flex-col gap-6 items-center justify-start relative w-full">
      <div class="slides-viewport relative w-full overflow-hidden">
        <div class="slides-track flex relative will-change-transform">
        {items.map((promotion: any, idx: number) => {
          const bgDesktop = promotion?.image?.desktop ?? '';
          return (
            <div class="promo-slide-full flex-shrink-0 w-full relative" data-slide-index={idx}>
              <div class="card-wrapper mx-auto w-full" style={`max-width: 1036px`}>
                <div class={`promo-carousel-card bg-white overflow-hidden rounded-[32px] md:rounded-[40px] w-full shadow-lg hover:shadow-xl transition-shadow ${isFinished ? 'opacity-75' : ''}`}>
                  <div class="flex flex-col md:flex-row md:h-[471px]">

                    {/* Image panel — full width on mobile, half on desktop */}
                    <div
                      class="relative w-full h-[240px] md:w-[517px] md:h-full flex-shrink-0 bg-center bg-cover bg-no-repeat"
                      style={`background-image: url('${bgDesktop}')`}
                    >
                      <div class={`absolute inset-0 bg-gradient-to-r from-transparent to-white/10 ${isFinished ? 'bg-black/20' : ''}`}></div>
                      {isFinished && (
                        <div class="absolute top-4 right-4 bg-red-600 text-white px-3 py-1.5 rounded-full text-xs font-bold z-10">
                          {currentLang === 'es' ? 'Finalizada' : 'Finished'}
                        </div>
                      )}
                    </div>

                    {/* Content panel — grows to fill remaining space */}
                    <div class="flex flex-col gap-4 md:gap-6 items-center justify-center flex-1 p-6 md:p-8">
                      <div class="flex flex-col gap-3 md:gap-4 items-center justify-start w-full">
                        <div class="flex gap-2 items-center justify-center md:justify-start">
                          <div class="flex items-center justify-center w-6 h-6">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-black">
                              <path d="M19 4h-1V3c0-.6-.4-1-1-1s-1 .4-1 1v1H8V3c0-.6-.4-1-1-1s-1 .4-1 1v1H5C3.3 4 2 5.3 2 7v12c0 1.7 1.3 3 3 3h14c1.7 0 3-1.3 3-3V7c0-1.7-1.3-3-3-3zm1 15c0 .6-.4 1-1 1H5c-.6 0-1-.4-1-1V10h16v9zm0-11H4V7c0-.6.4-1 1-1h1v1c0 .6.4 1 1 1s1-.4 1-1V6h8v1c0 .6.4 1 1 1s1-.4 1-1V6h1c.6 0 1 .4 1 1v1z"/>
                            </svg>
                          </div>
                          <p class="text-base md:text-xl text-black">
                            {isFinished ? (currentLang === 'es' ? 'Finalizada' : 'Finished') : formattedDate(promotion.startDate, promotion.endDate)}
                          </p>
                        </div>
                        <h3 class="text-2xl md:text-3xl font-sans font-bold text-black text-center leading-tight">
                          {promotion.title}
                        </h3>
                        {promotion.subtitle && (
                          <p class="text-sm text-gray-600 text-center px-2 md:px-4">
                            {promotion.subtitle}
                          </p>
                        )}
                      </div>

                      <a
                        href={promotion.buttonUrl}
                        class={`text-base md:text-xl px-6 md:px-8 py-3 md:py-4 rounded-full transition-colors ${
                          isFinished
                            ? 'bg-gray-500 text-white hover:bg-gray-600'
                            : 'bg-[#00306f] text-white hover:bg-blue-900'
                        }`}
                      >
                        {currentLang === 'es' ? 'Ver detalle' : 'View detail'}
                      </a>

                      <div class="flex gap-3 md:gap-4 items-center justify-center">
                        <span class="text-base md:text-xl text-black">
                          {currentLang === 'es' ? 'Comparte:' : 'Share:'}
                        </span>
                        <SocialShare
                          title={promotion.title}
                          className="flex gap-3"
                          buttonClassName="text-black hover:text-blue-600 transition-colors"
                          platforms={['facebook', 'twitter', 'whatsapp']}
                        />
                      </div>
                    </div>

                  </div>
                </div>
              </div>
            </div>
          );
        })}
        </div>
      </div>
    </div>
    
    {/* Carousel Navigation */}
    <div class="flex gap-6 items-center justify-center mt-6">
      <button 
        class="carousel-prev w-8 h-8 flex items-center justify-center text-white hover:text-gray-200 transition-colors cursor-pointer"
        aria-label={currentLang === 'es' ? 'Anterior promoción' : 'Previous promotion'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      
      <div class="flex items-center gap-2">
        {Array.from({ length: items.length }).map((_, index) => (
          <div class="w-10 h-10 flex items-center justify-center">
            <div 
              class={`dot w-4 h-4 rounded-full transition-colors ${index === 0 ? 'bg-white' : 'bg-[#a4aeb7] hover:bg-white/80'}`}
              role="button"
              data-dot-index={index}
              aria-label={`${currentLang === 'es' ? 'Ir a promoción' : 'Go to promotion'} ${index + 1}`}
            />
          </div>
        ))}
      </div>
      
      <button 
        class="carousel-next w-8 h-8 flex items-center justify-center text-white hover:text-gray-200 transition-colors cursor-pointer"
        aria-label={currentLang === 'es' ? 'Siguiente promoción' : 'Next promotion'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>

  <script>
    document.querySelectorAll('.promos-carousel').forEach(function(root){
      const slidesTrack = root.querySelector('.slides-track');
      const slidesViewport = root.querySelector('.slides-viewport');
      const slides = Array.from(root.querySelectorAll('.promo-slide-full'));
      if(slides.length === 0) return;
      const hasMultipleSlides = slides.length > 1;
      let current = 0;
      const prevBtn = root.querySelector('.carousel-prev');
      const nextBtn = root.querySelector('.carousel-next');
      const dots = Array.from(root.querySelectorAll('.dot'));
      const containerEl = root.querySelector('.promo-carousel-container');
      let containerWidth = slidesViewport ? slidesViewport.clientWidth : (containerEl ? containerEl.clientWidth : root.clientWidth);
      function setWidths(){
        containerWidth = slidesViewport ? slidesViewport.clientWidth : (containerEl ? containerEl.clientWidth : root.clientWidth);
        containerWidth = Math.max(0, Math.round(containerWidth));
        if (slidesTrack) {
          slidesTrack.style.width = `${slides.length * containerWidth}px`;
          slidesTrack.style.gap = '0px';
          slidesTrack.style.boxSizing = 'border-box';
          slides.forEach(sl => {
            sl.style.boxSizing = 'border-box';
            sl.style.flex = `0 0 ${containerWidth}px`;
            sl.style.width = `${containerWidth}px`;
            sl.style.paddingLeft = '0';
            sl.style.paddingRight = '0';
            sl.style.margin = '0';
          });
        }
      }
      setWidths();
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          setWidths();
          update(current, !hasMultipleSlides);
        }, 80);
      });

      function update(activeIndex, skipFade = false){
        const index = ((activeIndex % slides.length) + slides.length) % slides.length;
        const doSnap = () => {
          if (slidesTrack) {
            slidesTrack.style.transition = 'none';
            slidesTrack.style.transform = `translateX(-${index * containerWidth}px)`;
          }
          dots.forEach((d,i)=>{
            if(i === index){
              d.classList.remove('bg-[#a4aeb7]');
              d.classList.add('bg-white');
            } else {
              d.classList.remove('bg-white');
              d.classList.add('bg-[#a4aeb7]');
            }
          });
          current = index;
        };
        if (skipFade || !slidesViewport) {
          doSnap();
          return;
        }
        if (!hasMultipleSlides) {
          doSnap();
          return;
        }
        slidesViewport.style.transition = 'opacity 220ms ease';
        slidesViewport.style.opacity = '0';
        setTimeout(() => {
          doSnap();
          requestAnimationFrame(() => {
            slidesViewport.style.opacity = '1';
          });
        }, 220);
      }

      if (hasMultipleSlides) {
        prevBtn?.addEventListener('click', ()=> update((current - 1 + slides.length) % slides.length));
        nextBtn?.addEventListener('click', ()=> update((current + 1) % slides.length));
        dots.forEach(d => d.addEventListener('click', ()=> update(Number(d.dataset.dotIndex))));
      }

      // autoplay
      let autoplay;
      if (hasMultipleSlides) {
        autoplay = setInterval(()=> update(current + 1), 5000);
        root.addEventListener('mouseenter', ()=> clearInterval(autoplay));
        root.addEventListener('mouseleave', ()=> { autoplay = setInterval(()=> update(current + 1), 5000); });
      }

      // touch
      let startX = 0;
      let deltaX = 0;
      const threshold = 50;
      root.addEventListener('touchstart', (e) => {
        if (!hasMultipleSlides) return;
        startX = e.touches[0].clientX;
        deltaX = 0;
        if (slidesTrack) slidesTrack.style.transition = '';
        clearInterval(autoplay);
      }, { passive: true });
      root.addEventListener('touchmove', (e) => {
        if (!hasMultipleSlides) return;
        deltaX = e.touches[0].clientX - startX;
        if (slidesTrack) {
          slidesTrack.style.transform = `translateX(${ -current * containerWidth + deltaX }px)`;
        }
      }, { passive: true });
      root.addEventListener('touchend', () => {
        if (!hasMultipleSlides) return;
        if (Math.abs(deltaX) > threshold) {
          if (deltaX < 0) update(current + 1, true); else update(current - 1, true);
        } else {
          update(current, true);
        }
        autoplay = setInterval(()=> update(current + 1), 5000);
      });

      update(0, !hasMultipleSlides);
    });
  </script>
</div>
