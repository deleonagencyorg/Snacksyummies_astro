      </div>

      <!-- Right side: Social Media Share Modal -->
      <div class="flex flex-col md:flex-row gap-2 items-center md:items-center justify-between md:justify-start w-full md:w-auto mt-4 md:mt-0" data-name="Social media">
        <div class="flex items-center gap-2">
          <button class="flex gap-2 items-center justify-center md:justify-start hover:opacity-80 transition-opacity" onclick="window.showShareModal && window.showShareModal('recipeShareModal')">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"/>
            </svg>
            <span class="text-white text-xl font-sans" >
              {currentLang === 'es' ? 'Comparte en redes' : 'Share on social'}
            </span>
          </button>
          <ShareModal id="recipeShareModal" url={Astro.url.toString()} title={safeRecipe.title} description={safeRecipe.description} />
        </div>
        { /* Mobile: show product link under share button (stacked via flex-col on mobile) */ }
        {safeRecipe.Product && recipeBrandSlug && (
          <a
            href={`/${currentLang}/${currentLang === 'es' ? 'productos' : 'products'}?brand=${encodeURIComponent(recipeBrandSlug)}`}
            class="product-link-mobile md:hidden mt-2 md:mt-0 inline-flex justify-center items-center w-full text-center px-4 py-2 rounded-full bg-white text-primary font-semibold shadow-md hover:opacity-90"
          >
            <span class="w-full">{safeRecipe.Product}</span>
